# Copy to .env and fill in real values. Never commit .env.

# --- Google Sheets (required from Phase 4 onward) ---
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Notifications (required from Phase 5 onward) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# --- Pipeline tuning ---
SCORE_THRESHOLD_WRITE=40
SCORE_THRESHOLD_NOTIFY=70
